# ==========================================================
# MILJÖVARIABLER FÖR MDU ROBOTICS APP
# ==========================================================
# 1. Om du kör lokalt via Docker, låt dessa vara.
# 2. Om du publicerar på Render och AuraDB, kopiera dessa namngivningar till Renders kontrollpanel.

# Neo4j Database URI (Byt ut mot AuraDB URI vid publicering)
NEO4J_URI=bolt://localhost:7687

# Neo4j Username (Oftast "neo4j")
NEO4J_USERNAME=neo4j

# Neo4j Password (Ditt lösenord på AuraDB, eller "robotics2026" lokalt via Docker)
NEO4J_PASSWORD=robotics2026
